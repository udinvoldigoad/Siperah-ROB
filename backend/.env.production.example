# Template .env production SIPERAH-RoB (Hostinger shared + Supabase).
# Salin ke .env di server lalu isi semua nilai <...> — JANGAN commit nilai asli.
# Prosedur rotasi secret: docs/operations/secret-rotation.md (bila ada perubahan).

# ── Aplikasi ─────────────────────────────────────────────────────
APP_NAME=SIPERAH-RoB
APP_ENV=production
# Generate sekali di server: php artisan key:generate --show
APP_KEY=<base64-app-key>
APP_DEBUG=false
APP_URL=https://siperah-rob.girimulyo.com

# Log harian, hanya warning ke atas; retensi default 14 hari.
LOG_CHANNEL=daily
LOG_LEVEL=warning

# ── Database — Supabase PostgreSQL + PostGIS (session pooler) ────
# Gunakan SESSION pooler (port 5432), bukan transaction pooler: aplikasi
# memakai prepared statement & search_path yang tidak aman di mode transaksi.
DB_CONNECTION=pgsql
DB_HOST=<aws-0-ap-southeast-1.pooler.supabase.com>
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=<postgres.project-ref>
DB_PASSWORD=<db-password>

# ── Driver runtime (shared hosting, tanpa Redis) ─────────────────
FILESYSTEM_DISK=local
CACHE_STORE=file
SESSION_DRIVER=file
# Saat notifikasi multi-kanal aktif penuh: ganti ke `database` + cron
# `queue:work --stop-when-empty` (sudah terjadwal di bootstrap/app.php).
QUEUE_CONNECTION=sync

# ── Scheduler flags (cron hPanel tiap menit -> schedule:run) ─────
# ml:predict & backup:run sengaja OFF di Hostinger — prediksi harian jalan
# via GitHub Actions, backup via repo private (docs/operations/backup-database.md).
ML_SCHEDULE_ENABLED=false
BACKUP_SCHEDULE_ENABLED=false
# Password arsip backup (wajib bila BACKUP_SCHEDULE_ENABLED=true).
BACKUP_ARCHIVE_PASSWORD=

# ── Keamanan & batas laju ────────────────────────────────────────
# Deployment satu-origin: cukup domain resmi frontend.
CORS_ALLOWED_ORIGINS=https://siperah-rob.girimulyo.com
SANCTUM_STATEFUL_DOMAINS=siperah-rob.girimulyo.com
# Batas laju endpoint publik (per menit per IP) — bisa disetel tanpa deploy.
PUBLIC_RATE_LIMIT=180
PUBLIC_EXPORT_RATE_LIMIT=20
API_RATE_LIMIT=120
# Retensi audit log (hari) untuk audit:prune.
AUDIT_RETENTION_DAYS=365

# ── Web Push (VAPID) — generate: npx web-push generate-vapid-keys ─
VAPID_PUBLIC_KEY=<vapid-public-key>
VAPID_PRIVATE_KEY=<vapid-private-key>
VAPID_SUBJECT=mailto:admin@teratekno.my.id

# ── Email notifikasi ─────────────────────────────────────────────
# Isi SMTP bila kanal email diaktifkan; `log` = tulis ke log saja.
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=noreply@siperah-rob.girimulyo.com
MAIL_FROM_NAME=SIPERAH-RoB
